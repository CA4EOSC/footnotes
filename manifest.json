{
    "manifest_version": 3,
    "name": "Gemini CLI Sidebar",
    "version": "1.0",
    "description": "An extension that provides an embedded terminal linked to your local machine.",
    "permissions": [],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' ws://localhost:8765 ws://127.0.0.1:8765;"
    },
    "host_permissions": [
        "ws://localhost/*"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "gemini-cli-sidebar@localhost",
            "strict_min_version": "109.0"
        }
    },
    "sidebar_action": {
        "default_title": "Gemini CLI",
        "default_panel": "sidebar.html"
    },
    "background": {
        "scripts": [
            "background.js"
        ],
        "service_worker": "background.js",
        "type": "module"
    }
}